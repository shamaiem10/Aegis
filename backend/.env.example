# Copy to `.env` and fill in. Do not commit `.env` or service account JSON.

APP_ENV=development
DEBUG=true
PORT=8000
CORS_ORIGINS=*

# Firestore (optional)
FIREBASE_PROJECT_ID=
USE_FIRESTORE=false
# Absolute path to the downloaded service account JSON (Windows: C:\\Users\\you\\keys\\project-adminsdk.json)
GOOGLE_APPLICATION_CREDENTIALS=

# GCP / Gemini (optional)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=false
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
