# FastAPI backend (no Google keys here — those go on the server `.env`)
#
# Copy this file to `.env` and set your PC LAN IP for real-device testing, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.50:8000
# Dev builds default to live API (not mock). If you skip this, open Settings and
# set the same URL there, with uvicorn on 0.0.0.0 and Windows firewall open.
#
# Expo Go / Metro: default `npm start` uses LAN so QR is exp://<PC-ip>:8081 (not 127.0.0.1).
# If scan still fails: `npm run start:tunnel`, turn off VPN, or allow Node in Windows Firewall (Private).

# Emulator: Android http://10.0.2.2:8000 · iOS sim http://127.0.0.1:8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Later: optional Map SDK keys for standalone / dev-client builds only
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase client (Firestore real-time hooks). Values from Firebase Console → Project settings.
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=aegis-496207.firebaseapp.com
# EXPO_PUBLIC_GCP_PROJECT_ID=aegis-496207
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=aegis-496207.appspot.com
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_GCP_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

#
# Expo Go QR "Something went wrong" — usually networking or SDK mismatch:
# - Phone and PC must reach Metro (port 8081). Same Wi-Fi; try: npm run start:tunnel
# - Windows: allow Node.js / port 8081 inbound in Firewall
# - Expo Go must support SDK 54 (update from App Store / Play Store)
# - Start only from frontend/mobile: npx expo start -c
#
