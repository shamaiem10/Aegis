{
  "name": "aegis-mobile",
  "version": "1.0.0",
  "main": "index.tsx",
  "type": "commonjs",
  "scripts": {
    "start": "expo start --lan",
    "start:device": "powershell -ExecutionPolicy Bypass -NoProfile -File ./scripts/start-with-lan-ip.ps1",
    "android:usb-api": "powershell -ExecutionPolicy Bypass -NoProfile -File ./scripts/android-usb-api.ps1",
    "start:8082": "expo start --lan --port 8082",
    "start:clear": "expo start -c --lan",
    "start:localhost": "expo start",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "prebuild:android": "expo prebuild --platform android",
    "build:apk": "npx eas-cli build --platform android --profile preview",
    "build:apk:stage": "powershell -ExecutionPolicy Bypass -NoProfile -File ./scripts/build-apk-download.ps1",
    "build:apk:prod": "npx eas-cli build --platform android --profile production",
    "seed": "npx ts-node scripts/seedFirestore.ts",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.0",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^11.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/react": "~19.1.0",
    "eas-cli": "^16.32.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-admin": "^13.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "ts-node": {
    "project": "tsconfig.seed.json",
    "transpileOnly": true
  },
  "private": true
}
