{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "ts-node": {
    "esm": false,
    "transpileOnly": true
  },
  "include": ["scripts/seedFirestore.ts", "src/**/*"]
}
